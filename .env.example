# Portugal Data Intelligence — Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (optional — rule-based insights work without it)
OPENAI_API_KEY=your_api_key_here

# Database path (optional — defaults to data/database/portugal_data_intelligence.db)
# DATABASE_PATH=

# Log level (optional — defaults to INFO)
# LOG_LEVEL=INFO

# API configuration (optional)
# API_KEY=                     # Set to require X-API-Key header on API requests
# API_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# Data quality (optional)
# DQ_FAIL_ON_ERROR=false       # Set to true to fail pipeline on DQ errors
