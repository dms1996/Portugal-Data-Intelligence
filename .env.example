# Portugal Data Intelligence — Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (optional — rule-based insights work without it)
OPENAI_API_KEY=your_api_key_here

# Database path (optional — defaults to data/database/portugal_data_intelligence.db)
# DATABASE_PATH=

# Log level (optional — defaults to INFO)
# LOG_LEVEL=INFO
