# =============================================================================
# Portugal Data Intelligence - .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl

# Virtual Environments
venv/
env/
.env/
.venv/
ENV/

# Environment Variables / Secrets
.env
.env.local
.env.*.local
*.secret
api_keys.json

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data Files (large files - keep structure, ignore content)
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.json
data/raw/*.sha256
data/raw/*.meta.json
data/processed/*.csv
data/processed/*.xlsx
data/processed/*.parquet
data/database/*.db
data/database/*.sqlite
data/database/*.sqlite3

# Logs
logs/
*.log

# Generated HTML reports
dashboard/pages/*.html
dashboard/*.html

# Reports (generated outputs)
reports/powerbi/*.pbix
reports/powerbi/charts/*.png
reports/powerpoint/*.pptx
reports/powerpoint/*.pdf
reports/insights/*.json
reports/data_quality/*.json
reports/alerts/*.json
reports/backtesting_results.json
reports/ad_hoc/*.png

# MkDocs build output
site/

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Distribution / Packaging
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
.claude/

# API cache
.api_cache/
