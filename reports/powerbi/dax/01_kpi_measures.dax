// -----------------------------------------------------------------------------
Latest Budget Balance =
VAR _LastDate =
    CALCULATE(
        MAX(fact_public_debt[date_key]),
        ALLSELECTED(dim_date)
    )
RETURN
    CALCULATE(
        AVERAGE(fact_public_debt[budget_deficit]),
        fact_public_debt[date_key] = _LastDate
    ) / 100
