// =============================================================================
// KPI Measures - Portugal Data Intelligence
// Latest values for executive dashboard KPI cards
// =============================================================================

// Setup: Measures Table
_Measures = ROW("Placeholder", BLANK())


// -----------------------------------------------------------------------------
// 1.1 Latest GDP (Nominal)
// Returns the most recent nominal GDP value in EUR millions.
// Display Folder: KPI Measures | Format: #,##0 "M"
// Used On: Page 1 (Executive Overview), Page 2 (GDP & Growth)
// -----------------------------------------------------------------------------
Latest GDP =
VAR _LastDate =
    CALCULATE(
        MAX(fact_gdp[date_key]),
        ALLSELECTED(dim_date)
    )
RETURN
    CALCULATE(
        SUM(fact_gdp[nominal_gdp]),
        fact_gdp[date_key] = _LastDate
    )


// -----------------------------------------------------------------------------
// 1.2 Latest GDP Growth
// Returns the most recent year-on-year GDP growth rate.
// Display Folder: KPI Measures | Format: +0.0%;-0.0%;0.0%
// Used On: Page 1 (Executive Overview), Page 2 (GDP & Growth)
// -----------------------------------------------------------------------------
Latest GDP Growth =
VAR _LastDate =
    CALCULATE(
        MAX(fact_gdp[date_key]),
        ALLSELECTED(dim_date)
    )
RETURN
    CALCULATE(
        SUM(fact_gdp[gdp_growth_yoy]),
        fact_gdp[date_key] = _LastDate
    ) / 100


// -----------------------------------------------------------------------------
// 1.3 Latest GDP Per Capita
// Returns the most recent GDP per capita value in EUR.
// Display Folder: KPI Measures | Format: EUR#,##0
// Used On: Page 1 (Executive Overview), Page 2 (GDP & Growth)
// -----------------------------------------------------------------------------
Latest GDP Per Capita =
VAR _LastDate =
    CALCULATE(
        MAX(fact_gdp[date_key]),
        ALLSELECTED(dim_date)
    )
RETURN
    CALCULATE(
        AVERAGE(fact_gdp[gdp_per_capita]),
        fact_gdp[date_key] = _LastDate
    )


